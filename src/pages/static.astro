---
import songs from '../data/songs.json';
import SongCard from '../components/songCard.astro';
import SongCard2 from '../components/songCard2.astro';
import './src/styles/global.css';
---


<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Concert Setlist</title>
  </head>
  <body class="bg-gray-100 text-gray-800 dark:bg-gray-950 dark:text-gray-100 font-sans">
    <main class="max-w-3xl mx-auto p-4">
	<button
        id="toggle-dark"
        aria-label="Toggle Dark Mode"
        class="fixed top-4 right-4 mb-4 p-2 rounded bg-gray-300 dark:bg-gray-700"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
  			<path id = "icon-path" stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
		</svg>
      </button>
      <h1 class="text-3xl font-bold mb-6">Concert Setlist</h1>

      {songs.map(song => (
        <SongCard {...song} />
      ))}
    </main>
	<script>
		if (localStorage.getItem('theme') !== 'light') {
   	 		document.documentElement.classList.add('dark');
  		}

		const darkModeButton = document.getElementById("toggle-dark");
		const path = document.getElementById('icon-path');

		const sun = `M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z`
		const moon = `M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z`

		if (darkModeButton) darkModeButton.addEventListener("click", () => {
			const html = document.documentElement;
			html.classList.toggle('dark');
			
			if (html.classList.contains('dark')) {
				localStorage.setItem('theme', 'dark');
				if (path) path.setAttribute('d',sun); 

			} else {
				localStorage.setItem('theme', 'light');
				if (path) path.setAttribute('d',moon);
			}
		}
	  )
		
      

      window.addEventListener('DOMContentLoaded', () => {
        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark') {
          document.documentElement.classList.add('dark');
        }
      });
    </script>
  </body>
</html>
