---
type Social = { name: string; url: string; icon: string };

const {
  songName,
  interpreterName,
  interpreterImage,
  interpreterSocials,
  albumImage,
  originalArtistName,
  composers,
  description,
  songLink,
} = Astro.props as {
  songName: string;
  interpreterName: string;
  interpreterImage: string;
  interpreterSocials: Social[];
  albumImage: string;
  originalArtistName: string;
  composers: string;
  description: string;
  songLink?: string;
};
---

<div
  class="flip-card fade-in w-full min-h-[450px] rounded-xl overflow-hidden [transform-style:preserve-3d] bg-white dark:bg-gray-900 hover:shadow-lg mx-auto dark:shadow-cyan-700/20"
  aria-label="Tarjeta de canción"
>
  <div class="flip-inner w-full h-full relative transition-transform duration-750 [transform-style:preserve-3d] ease-in-out">
    <!-- Front -->
    <div
  class="absolute inset-0 backface-hidden p-6 flex flex-col justify-between text-center space-y-3"
>
  <div>
    <h2 class="text-xl font-bold text-gray-900 dark:text-white">{songName}</h2>
    <img
      src={interpreterImage}
      alt={`Imagen de ${interpreterName}`}
      class="w-24 h-24 object-cover rounded-full mx-auto my-4"
    />
    <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200">{interpreterName}</h3>
    <div class="flex flex-wrap justify-center space-x-4 mt-2">
      {interpreterSocials?.map(({ name, url, icon }) => (
        <a href={url} target="_blank" rel="noopener noreferrer" aria-label={name}>
          <img src={icon} alt={name} class="w-6 h-6 hover:scale-110 transition" />
        </a>
      ))}
    </div>
  </div>

  <button
    type="button"
    class="mt-auto px-4 py-2 bg-gray-200 dark:bg-gray-700 text-gray-800 dark:text-white rounded hover:bg-gray-300 dark:hover:bg-gray-600 transition"
    onclick= "this.closest('.flip-card')?.classList.add('flipped')"
    
  >
    Más información
  </button>
</div>

<!-- Back -->
<div
  class="absolute inset-0 backface-hidden rotate-y-180 p-6 flex flex-col justify-between text-center space-y-3 bg-gray-50 dark:bg-gray-800"
>
  <div>
    <h2 class="text-xl font-bold text-gray-900 dark:text-white">{songName}</h2>
    <img
      src={albumImage}
      alt={`Portada del álbum de ${songName}`}
      class="w-24 h-24 object-cover rounded-md mx-auto my-4"
    />
    <h3 class="text-lg font-semibold text-gray-800 dark:text-gray-200">{originalArtistName}</h3>
    <p class="text-sm italic text-gray-600 dark:text-gray-400">Compositores: {composers}</p>
    <p class="text-gray-700 dark:text-gray-300 mt-2">{description}</p>

    {songLink && (
      <a
        href={songLink}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block mt-4 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700 transition"
      >
        Escuchar canción
      </a>
    )}
  </div>

  <button
    type="button"
    class="mt-auto px-4 py-2 bg-gray-300 dark:bg-gray-700 text-gray-900 dark:text-white rounded hover:bg-gray-400 dark:hover:bg-gray-600 transition"
    onclick="this.closest('.flip-card')?.classList.remove('flipped')"
  >
    Volver
  </button>
</div>
  </div>
</div>

<style>
  .backface-hidden {
    backface-visibility: hidden;
    transform-style: preserve-3d;
  }
  .rotate-y-180 {
    transform: rotateY(180deg);
  }
  .flip-card.flipped .flip-inner {
    transform: rotateY(180deg);
  }

   /* Fade-in animation */
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  .fade-in {
    animation: fadeIn 0.8s ease-out;
  }

</style>
